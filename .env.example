# ==============================================================================
# TagTales Gallery - Environment Templates & Operational Configuration
# ==============================================================================
# This file lists the system configuration options needed in production.
# Ensure all required API keys are configured to prevent fallback/simulated mode.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ------------------------------------------------------------------------------
# 1. GOOGLE GEMINI AI & PAGESPEED CONFIGURATION
# ------------------------------------------------------------------------------
# Required for translations (bulk translating admin content IT -> EN) and client 
# assistant. If missing, translations and AI tools will throw error responses.
GEMINI_API_KEY=""

# Optional: Dedicated Google API key for PageSpeed Insights API. 
# If not declared, the backend will attempt to fallback to GEMINI_API_KEY (if a standard AIzaSy developer key).
# If both are omitted (or restricted), the API may run into public IP quota limits on Cloud Run.
PAGESPEED_API_KEY=""

# ------------------------------------------------------------------------------
# 2. ECWID STORE INTEGRATION
# ------------------------------------------------------------------------------
# Configures the digital storefront connection for synchronization of inventory
# and payment links on physical and digital art sales.
# ECWID_STORE_ID: The Store ID for Ecwid integration
ECWID_STORE_ID=""

# ECWID_SECRET_TOKEN: The secret token for Ecwid REST API
ECWID_SECRET_TOKEN=""

# ------------------------------------------------------------------------------
# 3. SENDFOX NEWSLETTER SYSTEM
# ------------------------------------------------------------------------------
# Requires verified verified From Name and Email to successfully dispatch
# and create draft newsletter campaigns.
# If SENDFOX_ACCESS_TOKEN is missing, the backend will fallback to offline/simulated newsletter storage.
# SENDFOX_ACCESS_TOKEN: Standard raw api secret token for SendFox
SENDFOX_ACCESS_TOKEN=""

# SENDFOX_ACCESS_TOKEN_BASE64: Alternative option for specific web hosting environments (like Hostinger)
# where raw authorization headers are restricted, filtered, or contain characters that trigger syntax issues.
# If configured, the backend automatically decodes this from Base64 before dispatching requests.
SENDFOX_ACCESS_TOKEN_BASE64=""

# SENDFOX_DEFAULT_LIST_ID: Optional default list ID to subscribe newsletters/new writers to
SENDFOX_DEFAULT_LIST_ID=""

# SENDFOX_FROM_NAME: Default sender name for campaigns created via API
SENDFOX_FROM_NAME="TagTales Gallery"

# SENDFOX_FROM_EMAIL: Sender email address verified on your SendFox account
SENDFOX_FROM_EMAIL="info@tagtales.gallery"

# ------------------------------------------------------------------------------
# 4. EMAIL DISPATCH SYSTEM (Direct Server SMTP & Resend)
# ------------------------------------------------------------------------------
# Configure SMTP details OR Resend API key for direct server-side email dispatch.
# If configured, emails (new registration, chat alerts, contact form) are sent instantly.
# 
# Option A: Resend API (Highly recommended, modern, 3000 free emails/month)
# RESEND_API_KEY="re_..."
# 
# Option B: Standard SMTP Credentials
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false" # set to "true" for port 465
# SMTP_USER="your-email@example.com"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="info@tagtales.gallery"
# 
# ------------------------------------------------------------------------------
# 5. FIREBASE OPTIONAL CONFIGURATION (Fallback / Multi-environment)
# ------------------------------------------------------------------------------
# If you are deploying the server custom package to Cloud Run under a non-default
# Firebase project, you can declare these to redirect connection routing.
# FIREBASE_PROJECT_ID=
# FIREBASE_DATABASE_ID=
