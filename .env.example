# ==============================================================================
# TagTales Gallery - Environment Templates & Operational Configuration
# ==============================================================================
# Copy to .env for local development. Never commit .env (gitignored).
# Production (Hostinger): see docs/DEPLOY.md

APP_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# 1. GOOGLE GEMINI AI & PAGESPEED
# ------------------------------------------------------------------------------
GEMINI_API_KEY=""
PAGESPEED_API_KEY=""
# Hostinger may also set GOOGLE_API_KEY (separate from GEMINI in some setups)

# ------------------------------------------------------------------------------
# 2. ECWID STORE
# ------------------------------------------------------------------------------
ECWID_STORE_ID=""
ECWID_SECRET_TOKEN=""
# Hostinger: ECWID_CLIENT_SECRET — must match ECWID_SECRET_TOKEN if both set

# ------------------------------------------------------------------------------
# 3. SENDFOX NEWSLETTER
# ------------------------------------------------------------------------------
SENDFOX_ACCESS_TOKEN=""
SENDFOX_ACCESS_TOKEN_BASE64=""
SENDFOX_DEFAULT_LIST_ID=""
SENDFOX_FROM_NAME="TagTales Gallery"
SENDFOX_FROM_EMAIL="tagtales@brignole.ch"

# ------------------------------------------------------------------------------
# 4. EMAIL (Resend recommended)
# ------------------------------------------------------------------------------
RESEND_API_KEY=""
SMTP_FROM="tagtales@brignole.ch"

# Optional SMTP fallback
# SMTP_HOST= SMTP_PORT=587 SMTP_USER= SMTP_PASS=

# ------------------------------------------------------------------------------
# 5. FIREBASE (optional overrides)
# ------------------------------------------------------------------------------
# FIREBASE_PROJECT_ID=
# FIREBASE_DATABASE_ID=

# ------------------------------------------------------------------------------
# 6. FIREBASE ADMIN (local dev login + server-side)
# ------------------------------------------------------------------------------
# Option A: file serviceAccountKey.json in project root (gitignored)
# Option B: base64-encoded JSON (same as Hostinger FIREBASE_SERVICE_ACCOUNT_BASE64)
FIREBASE_SERVICE_ACCOUNT_BASE64=""

# Fallback dev login if custom token unavailable:
# DEV_ADMIN_PASSWORD=""

# ------------------------------------------------------------------------------
# 7. META / ANALYTICS (production Hostinger)
# ------------------------------------------------------------------------------
META_PIXEL_ACCESS_TOKEN=""
