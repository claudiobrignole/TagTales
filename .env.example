# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ECWID_STORE_ID: The Store ID for Ecwid integration
ECWID_STORE_ID=""

# ECWID_SECRET_TOKEN: The secret token for Ecwid REST API
ECWID_SECRET_TOKEN=""

# SENDFOX_ACCESS_TOKEN: The Personal Access Token for the SendFox REST API
SENDFOX_ACCESS_TOKEN=""

# SENDFOX_DEFAULT_LIST_ID: Optional default list ID to subscribe newsletters to
SENDFOX_DEFAULT_LIST_ID=""

# SENDFOX_FROM_NAME: Optional sender name for campaigns created via API
SENDFOX_FROM_NAME="TagTales Gallery"

# SENDFOX_FROM_EMAIL: Sender email address verified on your SendFox account
SENDFOX_FROM_EMAIL="info@tagtales.gallery"
